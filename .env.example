# Server-only ThingsBoard configuration. Do not prefix these with VITE_ or NEXT_PUBLIC_.
TB_BASE_URL=https://thingsboard.cloud
TB_DEVICE_ID=replace-with-eco-01-device-id
TB_API_KEY=replace-with-thingsboard-api-key

# Alternative only when API key is unavailable. Use either TB_API_KEY OR TB_USERNAME + TB_PASSWORD.
# TB_USERNAME=your-thingsboard-email
# TB_PASSWORD=your-thingsboard-password

# Optional display labels for the Vercel dashboard.
TB_DEVICE_NAME=ECO-01
TB_DEVICE_LOCATION=Fakultas Teknik
